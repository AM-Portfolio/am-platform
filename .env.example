# ============================================================
# AM PLATFORM — ENVIRONMENT VARIABLES TEMPLATE
# ⚠️  This file IS committed to git. No real secrets here.
# Copy this to .secrets.env and fill in real values.
# ============================================================

# ============================================================
# KEYCLOAK ADMIN (Master Realm — used only for Admin REST API)
# am-identity obtains admin tokens from .../realms/master/.../token (admin-cli).
# Do not point admin credentials at the am-realm OIDC_TOKEN_URL below.
# ============================================================
KEYCLOAK_URL=http://auth.munish.org/auth
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<ask-team-lead>
KEYCLOAK_REALM=am-realm

# ============================================================
# OIDC ENDPOINTS (am-realm — user tokens, refresh, service accounts)
# ============================================================
OIDC_DISCOVERY_URL=http://auth.munish.org/auth/realms/am-realm/.well-known/openid-configuration
OIDC_ISSUER=http://auth.munish.org/auth/realms/am-realm
OIDC_JWKS_URL=http://auth.munish.org/auth/realms/am-realm/protocol/openid-connect/certs
OIDC_TOKEN_URL=http://auth.munish.org/auth/realms/am-realm/protocol/openid-connect/token

# ============================================================
# GOOGLE SSO (Keycloak broker + Terraform TF_VARs)
# ============================================================
GOOGLE_IDP_ALIAS=google
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_STATE_TTL_SECONDS=300
ALLOWED_GOOGLE_REDIRECT_URIS=http://localhost:9000/callback,https://am.munish.org/callback,https://am.asrax.in/callback,https://am-dev.asrax.in/callback

# ============================================================
# PUBLIC CLIENTS — No secret required (use with PKCE)
# ============================================================
AM_WEB_CLIENT_ID=am-web-client
AM_DIAGNOSTIC_CLIENT_ID=am-diagnostic-client
AM_ANDROID_CLIENT_ID=am-android-client
AM_IOS_CLIENT_ID=am-ios-client

# ============================================================
# CONFIDENTIAL SERVICE CLIENTS — Get secrets from 1Password / Vault
# ============================================================
AM_IDENTITY_CLIENT_ID=am-identity-service
AM_IDENTITY_CLIENT_SECRET=<get-from-vault>

AM_GATEWAY_CLIENT_ID=am-gateway-client
AM_GATEWAY_CLIENT_SECRET=<get-from-vault>

AM_GATEWAY_STREAMING_CLIENT_ID=am-gateway-streaming-service
AM_GATEWAY_STREAMING_CLIENT_SECRET=<get-from-vault>

AM_MCP_CLIENT_ID=am-mcp-service
AM_MCP_CLIENT_SECRET=<get-from-vault>

AM_FIN_AGENT_CLIENT_ID=am-fin-agent-service
AM_FIN_AGENT_CLIENT_SECRET=<get-from-vault>

AM_DOC_INTELLIGENCE_CLIENT_ID=am-doc-intelligence-service
AM_DOC_INTELLIGENCE_CLIENT_SECRET=<get-from-vault>

AM_ANALYSIS_CLIENT_ID=am-analysis-service
AM_ANALYSIS_CLIENT_SECRET=<get-from-vault>

AM_MARKET_CLIENT_ID=am-market-service
AM_MARKET_CLIENT_SECRET=<get-from-vault>

AM_MARKET_DATA_CLIENT_ID=am-market-data-service
AM_MARKET_DATA_CLIENT_SECRET=<get-from-vault>

AM_MARKET_PARSER_CLIENT_ID=am-market-parser-service
AM_MARKET_PARSER_CLIENT_SECRET=<get-from-vault>

AM_PORTFOLIO_CLIENT_ID=am-portfolio-service
AM_PORTFOLIO_CLIENT_SECRET=<get-from-vault>

AM_TRADE_CLIENT_ID=am-trade-service
AM_TRADE_CLIENT_SECRET=<get-from-vault>

AM_SUBSCRIPTION_CLIENT_ID=am-subscription-service
AM_SUBSCRIPTION_CLIENT_SECRET=<get-from-vault>

AM_NOTIFICATION_CLIENT_ID=am-notification-service
AM_NOTIFICATION_CLIENT_SECRET=<get-from-vault>

# ============================================================
# DATABASE
# ============================================================
POSTGRES_HOST=postgresql.infra.svc.cluster.local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<get-from-vault>
POSTGRES_DB=portfolio

# Subscription / Lago logical database (provisioned via tf:billing:apply)
AM_SUBSCRIPTION_DB_NAME=subscription
AM_SUBSCRIPTION_DB_USER=am_subscription_user
AM_SUBSCRIPTION_DB_PASSWORD=<generated-by-tf-billing-apply-or-secrets>
# Local dev only — cluster POSTGRES_HOST is not resolvable on laptop; use VPS TCP gateway
AM_SUBSCRIPTION_POSTGRES_HOST=postgres.asrax.in
AM_SUBSCRIPTION_POSTGRES_PORT=8891
# If gateway is stale (connection closed mid-handshake), redeploy VPS proxies:
#   npm run infra:tcp:redeploy
# TCP gateway is plain Postgres wire protocol (no TLS termination)
AM_SUBSCRIPTION_POSTGRES_SSL=false

# Lago Helm (deploy:lago) — external Redis in infra namespace (requirepass enabled)
REDIS_HOST=redis.infra.svc.cluster.local
REDIS_PASSWORD=<same-as-am-infra-redis>
# Optional override (must include password): redis://:PASSWORD@redis.infra.svc.cluster.local:6379/0
# LAGO_REDIS_URL=

# Lago public ingress (Traefik on VPS; TLS usually terminated at Cloudflare)
LAGO_HOSTNAME=lago.munish.org
LAGO_API_HOSTNAME=lago-api.munish.org
LAGO_ASRAX_HOSTNAME=lago.asrax.in
LAGO_ASRAX_API_HOSTNAME=lago-api.asrax.in
LAGO_AM_PATH_HOST=am.asrax.in
LAGO_PUBLIC_SCHEME=https
# LAGO_FRONT_URL=https://lago.munish.org
# LAGO_API_URL defaults to LAGO_FRONT_URL (same-host API routing in ingress)
# LAGO_API_URL=https://lago.munish.org

# Lago admin UI (created by deploy:lago via migrate seed; password in .secrets.env)
LAGO_ADMIN_EMAIL=billing-admin@munish.org
LAGO_ORG_NAME=AM Platform
# LAGO_ADMIN_PASSWORD=<in-.secrets.env>
# LAGO_ORG_API_KEY=<in-.secrets.env>

# ============================================================
# AM SUBSCRIPTION SERVICE (port 8110)
# ============================================================
APP_PORT=8110
LOG_LEVEL=INFO
DEFAULT_PLAN_CODE=am_free
LAGO_API_URL=https://lago.munish.org
# LAGO_ORG_API_KEY=<in-.secrets.env>
# LAGO_WEBHOOK_SECRET=<optional>

AM_LAGO_CLIENT_ID=am-lago-client
AM_LAGO_CLIENT_SECRET=<get-from-tf-keycloak-output>

# ============================================================
# SHARED INFRA — MongoDB (existing cluster, scoped users per service)
# ============================================================
MONGODB_HOST=mongodb.infra.svc.cluster.local
MONGODB_ADMIN_USER=admin
MONGODB_ADMIN_PASSWORD=<get-from-vault>

# Notification logical DB (provisioned via tf:notification:apply)
AM_NOTIFICATION_DB_NAME=notification
AM_NOTIFICATION_DB_USER=am_notification_user
AM_NOTIFICATION_DB_PASSWORD=<generated-by-tf-notification-apply-or-secrets>
AM_NOTIFICATION_MONGO_URI=mongodb://am_notification_user:<password>@mongodb.asrax.in:8888/notification?authSource=admin&directConnection=true
AM_NOTIFICATION_MONGO_DATABASE=notification
# Local dev only — cluster MONGODB_HOST is not resolvable on laptop
AM_NOTIFICATION_MONGO_HOST=mongodb.asrax.in
AM_NOTIFICATION_MONGO_PORT=8888

# Novu external DB on same shared Mongo cluster
NOVU_DB_NAME=novu
NOVU_DB_USER=novu_user
NOVU_DB_PASSWORD=<generated-by-tf-notification-apply-or-secrets>
# NOVU_MONGO_URI=<set-by-deploy-novu-in-.secrets.env>

# ============================================================
# SHARED INFRA — Kafka (existing broker, SCRAM-SHA-256)
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka.infra.svc.cluster.local:9092
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=<infra-kafka-user>
KAFKA_PASSWORD=<from-secrets>
# Local dev only — TCP gateway
AM_NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=kafka.asrax.in:8890

# ============================================================
# NOVU HELM (deploy:novu) — notification namespace
# ============================================================
NOVU_HOSTNAME=novu.munish.org
NOVU_API_HOSTNAME=novu-api.munish.org
NOVU_ASRAX_HOSTNAME=novu.asrax.in
NOVU_PUBLIC_SCHEME=https
NOVU_API_URL=https://novu-api.munish.org
NOVU_FRONT_URL=https://novu.munish.org
# NOVU_API_KEY=<Production key in .secrets.env — from Novu dashboard Settings -> API Keys>
# NOVU_DEV_API_KEY=<Development key in .secrets.env — for tf:notification workflow seed>
# NOVU_DEV_ENVIRONMENT_ID=6a1a0f38232b2b7f907f5860
# NOVU_JWT_SECRET=<in-.secrets.env>
# NOVU_STORAGE_KEY=<in-.secrets.env>
NOVU_REDIS_URL=redis://:<REDIS_PASSWORD>@redis.infra.svc.cluster.local:6379/2

# ============================================================
# AM NOTIFICATION SERVICE (port 8111)
# ============================================================
NOTIFICATION_PROVIDER=novu
NOVU_APPLICATION_IDENTIFIER=am-platform
KAFKA_ENABLED=false
KAFKA_NOTIFICATION_GROUP_ID=am-notification-consumer
KAFKA_NOTIFICATION_TOPICS=am.identity.events.v1,am.subscription.events.v1,am.usage.events.v1,am.notification.commands.v1
KAFKA_NOTIFICATION_EVENTS_TOPIC=am.notification.events.v1
KAFKA_NOTIFICATION_DLQ_TOPIC=am.notification.commands.dlq.v1

