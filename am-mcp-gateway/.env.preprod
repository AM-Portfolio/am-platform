# ── MCP Service Client Credentials ────────────────────────────────────────
AM_MCP_CLIENT_ID=am-mcp-service
AM_MCP_CLIENT_SECRET=hkk4698D7xZ8m2VpPL3zNfepAoTwRN8r

# ── LiteLLM (local port-forward to cluster) ───────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
