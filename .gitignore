# ============================================================
# CREDENTIALS — NEVER COMMIT THESE
# ============================================================
.secrets.env
*.secrets.env
.secrets.*.env
secrets/
**/.secrets/

# Postman environments (contain credentials)
postman/AM-Platform.dev.postman_environment.json
postman/AM-Platform.preprod.postman_environment.json
postman/AM-Platform.prod.postman_environment.json

# Terraform generated outputs (contain tokens and client secrets)
automation/terraform/keycloak/*_outputs.json

# ============================================================
# TERRAFORM STATE — contains plaintext secrets after apply
# ============================================================
**/*.tfstate
**/*.tfstate.*
**/*.tfplan
automation/terraform/**/.terraform/
automation/terraform/.terraform/
automation/terraform/.terraform.lock.hcl
automation/.bin/

# ============================================================
# TERRAFORM SECRETS — per-environment var files (contain creds)
# ============================================================
automation/terraform/keycloak/terraform.dev.tfvars
automation/terraform/keycloak/terraform.preprod.tfvars
automation/terraform/keycloak/terraform.prod.tfvars
automation/terraform/keycloak/generated.auto.tfvars.json
automation/terraform/**/generated.auto.tfvars.json


# ============================================================
# ENVIRONMENT FILES — real values only in .env.example (safe)
# ============================================================
.env
.env.local
.env.*.local
!.env.example
automation/helm/lago-admin.generated.yaml
automation/helm/*-admin.generated.yaml
**/kubeconfig*
**/*.pem
**/*.key
**/*.p12
**/*.pfx

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/

# ============================================================
# NODE / NPM
# ============================================================
node_modules/

# ============================================================
# RUNTIME LOGS (npm run-with-logs output)
# ============================================================
logs/*
!logs/README.md

# ============================================================
# OS / IDE
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
